    m_MinSize: 3
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "<size=48><b>AudioPlayback API Summary</b></size>\n<i>Lightweight, handle-based
    audio playback without MonoBehaviour.</i>\n\n\u2022 <b>Play a clip</b>  \n       
    var h = AudioPlayback.PlayClip(myClip, loop: false, volume: 1f, autoDisposeOnComplete:
    true);  \n        h.RegisterCompletedCallback(() => Debug.Log(\"Clip done\"),
    true);\n\n\u2022 <b>Stream audio</b>  \n        var h = AudioPlayback.CreateStream(1,
    48000, volume: 1f, autoDisposeOnComplete: true);  \n        h.Enqueue(samples,
    count, 1, 48000);  \n        h.CompleteStream();\n\n\u2022 <b>Control & status</b> 
    \n        h.Play(); h.Pause(); h.Stop();  \n        h.Volume = 1.0f; bool playing
    = h.IsPlaying; double secs = h.BufferedSeconds;  \n        h.Dispose();\n\n<color=#bbbbbb><i>Notes:</i>
    Supports looping, auto cleanup, background buffering. First stream chunk locks
    <b>channels/sampleRate</b>; mismatches are dropped.</color>"
